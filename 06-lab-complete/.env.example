# Copy thành .env (local dev) hoặc .env.local (docker compose). KHÔNG commit file thật.

# Server
HOST=0.0.0.0
PORT=8787
ENVIRONMENT=development

# App
APP_NAME=VinWonders AI Scheduler
APP_VERSION=1.0.0

# LLM (Gemini) — lấy key tại https://aistudio.google.com/app/apikey (bắt đầu bằng AIza)
GEMINI_API_KEY=your-key-here
GEMINI_MODEL=gemini-2.5-flash

# Security
# AGENT_API_KEY: để TRỐNG → /api/plan public (frontend gọi trực tiếp).
#                Đặt giá trị → bắt buộc header X-API-Key.
AGENT_API_KEY=
# CORS — dấu phẩy phân cách; "*" cho dev
ALLOWED_ORIGINS=*

# Rate limit & cost guard
RATE_LIMIT_PER_MINUTE=20
DAILY_CALL_BUDGET=1000
